# nginx static files server configuration
# Generated by RDT (Rambo Docker Tools)
# Place your static files in: {{ nginx_html_dir | default('./nginx/html') }}
# To customise, edit this file and run `rdt add nginx-static` again (existing files are not overwritten).

worker_processes auto;

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    sendfile        on;
    keepalive_timeout  65;

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;
    gzip_vary on;

    server {
        listen 80;
        server_name {{ nginx_server_name | default('localhost') }};

        root   /usr/share/nginx/html;
        index  index.html index.htm;

        # Cache static assets
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }

        location / {
            try_files $uri $uri/ =404;
        }
    }
}

