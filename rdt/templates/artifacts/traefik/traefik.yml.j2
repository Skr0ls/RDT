# traefik.yml — Static Traefik configuration
# Generated by RDT (Rambo Docker Tools)
# Documentation: https://doc.traefik.io/traefik/

# ---------------------------------------------------------------------------
# API & Dashboard
# ---------------------------------------------------------------------------
api:
  dashboard: {{ traefik_dashboard | default(true) | lower }}
  insecure: {{ traefik_dashboard_insecure | default(true) | lower }}

# ---------------------------------------------------------------------------
# Ping endpoint (used by healthcheck: wget -qO- http://localhost:8080/ping)
# ---------------------------------------------------------------------------
ping: {}

# ---------------------------------------------------------------------------
# Entry Points
# ---------------------------------------------------------------------------
entryPoints:
  web:
    address: ":80"
{% if traefik_https %}
  websecure:
    address: ":443"
{% if traefik_http_redirect %}
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true
{% endif %}
{% endif %}
  traefik:
    address: ":8080"

# ---------------------------------------------------------------------------
# Providers
# ---------------------------------------------------------------------------
providers:
  docker:
    exposedByDefault: false
    network: {{ network_name | default('rambo-net') }}
  file:
    directory: /etc/traefik/dynamic
    watch: true

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log:
  level: INFO

accessLog: {}

{% if traefik_https %}
# ---------------------------------------------------------------------------
# Let's Encrypt (ACME)
# ---------------------------------------------------------------------------
certificatesResolvers:
  myresolver:
    acme:
      email: {{ traefik_acme_email | default('admin@example.com') }}
      storage: /etc/traefik/certs/acme.json
      httpChallenge:
        entryPoint: web
{% endif %}

