# Filebeat configuration: output → Logstash (beats protocol)
# Generated by RDT (Rambo Docker Tools)
# Service: {{ service_name }}
# Mode: output-logstash
{% set logstash_host = filebeat_logstash_host | default(smart_env.FILEBEAT_LOGSTASH_HOST) | default('logstash:5044') %}
{% set kibana_host = filebeat_kibana_host | default(smart_env.FILEBEAT_KIBANA_HOST) | default('') %}

filebeat.inputs:
  - type: filestream
    id: default-filestream
    enabled: true
    paths:
      - {{ filebeat_log_path | default('/var/log/*.log') }}
    # Add more paths or inputs as needed

{% if kibana_host %}
setup.kibana:
  host: "{{ kibana_host }}"

{% endif %}
output.logstash:
  hosts: ["{{ logstash_host }}"]

processors:
  - add_host_metadata: ~
  - add_cloud_metadata: ~

# Logging
logging.level: info
logging.to_files: true
logging.files:
  path: /usr/share/filebeat/logs
  name: filebeat
  keepfiles: 7
  permissions: 0644

